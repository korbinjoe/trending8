{
  "name": "github-trending-plus",
  "license": "MIT",
  "scripts": {
    "dev": "pnpm --filter @github-trending/web dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "db:generate": "pnpm --filter @github-trending/db generate",
    "db:migrate": "pnpm --filter @github-trending/db migrate",
    "db:push": "pnpm --filter @github-trending/db push",
    "db:trgm": "pnpm --filter @github-trending/db trgm",
    "ingest:once": "pnpm --filter @github-trending/github ingest:once",
    "ranking:once": "pnpm --filter @github-trending/github ranking:once",
    "backfill:once": "pnpm --filter @github-trending/github backfill:once",
    "backfill:ranking": "pnpm --filter @github-trending/github backfill:ranking",
    "backfill:star-daily": "pnpm --filter @github-trending/github backfill:star-daily",
    "backfill:star-daily:ranking": "pnpm --filter @github-trending/github backfill:star-daily:ranking",
    "ph-ingest:once": "pnpm --filter @github-trending/producthunt ph-ingest:once",
    "ph-backfill:once": "pnpm --filter @github-trending/producthunt ph-backfill:once"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@9.15.0",
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "eslint": "^9.17.0",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.1"
  }
}
