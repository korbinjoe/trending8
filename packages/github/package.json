{
  "name": "@github-trending/github",
  "version": "0.0.1",
  "license": "MIT",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --max-warnings 0",
    "ingest:once": "tsx src/cli-ingest.ts",
    "ranking:once": "tsx src/cli-ingest.ts --ranking --ranking-only",
    "backfill:once": "tsx src/cli-backfill.ts",
    "backfill:ranking": "tsx src/cli-backfill.ts --ranking",
    "backfill:star-daily": "tsx src/cli-backfill-star-daily.ts",
    "backfill:star-daily:ranking": "tsx src/cli-backfill-star-daily.ts --ranking"
  },
  "dependencies": {
    "@github-trending/core": "workspace:*",
    "@github-trending/db": "workspace:*",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.38.3"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "eslint": "^10.5.0",
    "tsx": "^4.19.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1"
  }
}
